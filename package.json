{
  "name": "typescript-example",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "turbo run dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "canary:local": "pnpm --filter @glooai/canary run canary:local",
    "glooai:chat": "pnpm --filter @glooai/scripts run glooai:chat",
    "glooai:ingest": "pnpm --filter @glooai/scripts run glooai:ingest",
    "glooai:items": "pnpm --filter @glooai/scripts run glooai:items",
    "glooai:items:metadata": "pnpm --filter @glooai/scripts run glooai:items:metadata",
    "glooai:search": "pnpm --filter @glooai/scripts run glooai:search",
    "glooai:jwt": "pnpm --filter @glooai/scripts run glooai:jwt",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "prettier": "^3.3.3",
    "turbo": "^2.8.12"
  }
}
