# Copy to .env.local for local canary runs. In Cloud Run Jobs these are
# injected via Terraform from Secret Manager — do not commit real values.

CANARY_MODE=probe

# Gloo AI platform credentials (dedicated "canary" pair; do not reuse personal keys)
GLOO_AI_CLIENT_ID=
GLOO_AI_CLIENT_SECRET=

# Slack Web API (xoxb- bot token; channel ID, e.g. C0AU2FM2Q86)
ALERTS_SLACK_BOT_TOKEN=
ALERTS_SLACK_CHANNEL_ID=

# GCS bucket where run artifacts + state file live. Also stores the
# `state/model-registry-snapshot.json` blob used to diff the V2 model
# list between runs — no separate datastore needed.
CANARY_RESULTS_BUCKET=glooai-canary-results
